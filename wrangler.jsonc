{
  // Configuración para desplegar la app como sitio estático (Workers Static Assets).
  // Sirve el contenido de dist/ y hace fallback a index.html para las rutas del SPA.
  "name": "geriatria",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
